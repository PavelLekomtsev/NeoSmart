# Copy to `.env` (gitignored) and fill in as needed.
# Env vars take precedence over config/default.yaml.
#
# Nested keys use `__` as the delimiter. Examples:
#
#   NEOSMART_DETECTOR__CONFIDENCE=0.50
#   NEOSMART_LOGGING__LEVEL=DEBUG
#   NEOSMART_PATHS__FRAMES_DIR=/mnt/frames
#   NEOSMART_BARRIER__PLATE_MIN_AGREEING_READS=5
#
# Profile selection (loads config/<profile>.yaml on top of default.yaml):
#   NEOSMART_CONFIG_PROFILE=development
