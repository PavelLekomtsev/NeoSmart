# Trained model weights (too large / regenerated from training runs)
Models/Car_Detector.pt
yolo_car_detector.pt
Models/yolov8x.pt
Models/plate_scanner/

# SQLite runtime state
SmartParking/web_app/data/*.db

# Training / validation datasets (synthetic UE5 renders, too large for git)
Validation/data
Training/data
Training/output_images
Training/raw
Training/runs
Training/yolo11n.pt
Training/yolov8s.pt

# UE5-exported frames (runtime)
frames/

# Runtime logs
logs/

# Evaluation reports (regenerated by Validation/evaluate.py)
Validation/reports/

# Notebook artifacts — .py is the source of truth, .ipynb is a rendered view
# (see notebooks/build_ipynb.py). Stray Documentation/ inside notebooks/ can
# appear if the kernel runs with cwd=notebooks/ — belongs to a buggy run,
# never to git.
notebooks/*.ipynb
notebooks/.ipynb_checkpoints/
notebooks/Documentation/

# Python build / cache
__pycache__/
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtualenv / editor
.venv
.idea/

# Secrets / local config (ship *.example instead)
.env
.clearml.conf

# Agent / assistant state
CLAUDE.md
.claude
