# .clearml.conf.example — template for the ClearML SDK credentials file.
#
# Copy to either ~/.clearml.conf (user-global) or ./.clearml.conf (repo-local)
# and replace the placeholder credentials with the values generated by the
# ClearML web UI (Settings → Workspace → Create new credentials).
#
# The real .clearml.conf is gitignored. This example ships as documentation.
#
# Alternative: `clearml-init` walks through this interactively.

api {
    web_server:   http://localhost:8080
    api_server:   http://localhost:8008
    files_server: http://localhost:8081

    credentials {
        "access_key" = "PASTE_ACCESS_KEY_FROM_WEB_UI"
        "secret_key" = "PASTE_SECRET_KEY_FROM_WEB_UI"
    }
}

sdk {
    # Where intermediate files (models, artifacts, debug images) are
    # cached locally before upload.
    storage {
        cache {
            default_base_dir: "~/.clearml/cache"
            size { min_free_bytes = 10GB }
        }
    }

    development {
        # Upload trained models to the file server instead of just
        # registering a local path — needed for reproducibility across
        # machines.
        default_output_uri: "http://localhost:8081"

        # Capture git diff + uncommitted changes per task so a run can
        # be reproduced exactly.
        store_uncommitted_code_diff: true

        # Let Ctrl+C cleanly mark the task as aborted rather than failed.
        support_stopping: true
    }

    metrics {
        matplotlib_untitled_history_size: 100
    }
}
